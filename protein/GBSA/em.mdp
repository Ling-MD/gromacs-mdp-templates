define = -DFLEXIBLE
integrator = cg
nsteps = 500
emtol  = 100.0
emstep = 0.01
;
nstxout   = 50
nstlog    = 50
nstenergy = 50
;
pbc = no
rlist = 1.4
cutoff-scheme = group
coulombtype   = cut-off
rcoulomb      = 1.4
vdwtype       = cut-off
rvdw          = 1.4
;
constraints = none
implicit_solvent = GBSA
gb-algorithm = OBC
rgbradii = 1.4
gb-epsilon-solvent = 80
